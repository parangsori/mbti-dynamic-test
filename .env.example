VITE_POSTHOG_KEY=phc_your_project_api_key
VITE_POSTHOG_HOST=https://e.beatblue.net
VITE_PUBLIC_SERVICE_URL=https://todaymbti.com

# Server-session mode is required for production. This public flag contains no secret.
VITE_SERVER_SESSION_ENABLED=true

# Configure SESSION_TOKEN_SECRET, CONTENT_VAULT_KEY, and SESSION_MONITORING_SALT only in the server deployment environment.
# Never add real values here and never create VITE_ versions of those names.
SESSION_MONITORING_SALT=replace_with_a_long_random_server_only_value

# Optional Supabase result backup sync.
# Use publishable/anon client key only. Never put service role or secret keys in VITE_ variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Admin dashboard server-only variables live in admin/.env.example.
# Never prefix PostHog personal API keys with VITE_.
