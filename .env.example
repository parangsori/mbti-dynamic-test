VITE_POSTHOG_KEY=phc_your_project_api_key
VITE_POSTHOG_HOST=https://e.beatblue.net

# Optional Supabase result backup sync.
# Use publishable/anon client key only. Never put service role or secret keys in VITE_ variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Admin dashboard server-only variables live in admin/.env.example.
# Never prefix PostHog personal API keys with VITE_.
