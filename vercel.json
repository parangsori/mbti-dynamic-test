{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mbti-dynamic-test.vercel.app"
        }
      ],
      "destination": "https://todaymbti.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/build/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
